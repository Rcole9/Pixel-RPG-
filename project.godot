; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format is straightforward, the exporter handles it nicely.

config_version=5

[application]

config/name="Runes of the Void"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoloads/GameState.gd"
SaveLoad="*res://scripts/autoloads/SaveLoad.gd"
LootSystem="*res://scripts/systems/LootSystem.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

